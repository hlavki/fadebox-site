---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Features from "../components/Features.astro";
import HowItWorks from "../components/HowItWorks.astro";
import CiSection from "../components/CiSection.astro";
import Pricing from "../components/Pricing.astro";
import FinalCta from "../components/FinalCta.astro";
import Footer from "../components/Footer.astro";
import { showPricing } from "../data/landing";
---

<Layout
  title="Fadebox — Self-hosted ephemeral environments on plain Docker"
  description="One isolated copy of your stack per branch, per dev, per demo — each with its own URL. No Kubernetes. No SaaS control plane."
>
  <Nav />
  <Hero />
  <Features />
  <HowItWorks />
  <CiSection />
  {showPricing && <Pricing />}
  <FinalCta />
  <Footer />
</Layout>
