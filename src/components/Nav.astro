---
import { links, showPricing } from "../data/landing";
---

<nav class="nav container">
  <a class="brand" href="#" aria-label="fadebox — home">
    <img class="lockup" src="/logo-lockup.svg" alt="fadebox" width="128" height="26" />
  </a>
  <div class="spacer"></div>
  <a class="nav-link" href="#features">Features</a>
  <a class="nav-link" href="#how">How it works</a>
  {showPricing && <a class="nav-link" href="#pricing">Pricing</a>}
  <a class="nav-link" href={links.docs}>Docs</a>
  <a class="nav-cta" href="#cta">Get started</a>
</nav>

<style>
  .nav {
    display: flex;
    align-items: center;
    gap: 32px;
    padding-top: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }
  .lockup {
    display: block;
    height: 26px;
    width: auto;
  }
  .spacer {
    flex: 1;
  }
  .nav-link {
    font-size: 14px;
    text-decoration: none;
  }
  .nav-link:hover {
    text-decoration: underline;
  }
  .nav-cta {
    font-size: 14px;
    text-decoration: none;
    background: var(--brand);
    color: #fff;
    padding: 9px 18px;
    border-radius: var(--radius-btn);
    transition: background-color 0.15s ease;
  }
  .nav-cta:hover {
    background: var(--brand-hover);
    color: #fff;
  }

  @media (max-width: 720px) {
    .nav {
      flex-wrap: wrap;
      gap: 16px 20px;
    }
    .spacer {
      flex-basis: 100%;
      height: 0;
    }
  }
</style>
